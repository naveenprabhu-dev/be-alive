{"name": "BeAlive -- Block websites and start living!", 
"description": "BeAlive is a lightweight site blocker with motivational messages to help you stay focused. Stay distraction free and Be Alive!", 
"version": "1.0", 
"manifest_version": 3, 
"icons": {
  "16": "icon.png",
  "32": "icon.png",
  "48": "icon.png",
  "128": "icon.png"
},
"action": {
    "default_popup": "intro.html", 
    "default_icon": "icon.png"
},
"background": {
    "service_worker": "serviceWorker.js"
},
"host_permissions": ["<all_urls>"],
"permissions": ["tabs", "scripting", "storage"],
"options_ui": {
    "page": "opt.html",
    "open_in_tab": true
}, 
"web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.css"],
      "matches": ["<all_urls>"]
    }
  ]
    }